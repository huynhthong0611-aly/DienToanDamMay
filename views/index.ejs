<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Luxury Jewelry - Trang Sức Cao Cấp</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<div class="container">

<%- include('menu') %>

<!-- ===== BANNER ===== -->
<div class="banner mb-4">
    <img src="https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?w=1920" class="img-fluid rounded shadow">
    <div class="banner-text text-center mt-3">
        <h1 class="display-4 fw-bold">Luxury Jewelry</h1>
    </div>
</div>

<!-- ===== TOP RATED ===== -->
<div class="top-rated-section mt-5">
    <h2 class="title text-center mb-4">Sản Phẩm Mới</h2>

    <div class="row">

        <% if (typeof topRated !== 'undefined' && topRated.length > 0) { %>

            <% for (let i = 0; i < topRated.length; i++) { 
                let top_sp = topRated[i];
            %>

                <div class="col-md-3 mb-4">
                    <a href="/chitiet/<%= top_sp._id %>"
                       class="product-card h-100 border p-3 d-block text-decoration-none text-dark bg-white shadow-sm">

                        <div class="product-img text-center" style="height: 180px;">
                            <img src="../image/<%= top_sp.hinh_anh %>"
                                 class="img-fluid h-100"
                                 style="object-fit: contain;">
                        </div>

                        <h6 class="product-name mt-3 text-truncate fw-bold">
                            <%= top_sp.ten_sp %>
                        </h6>

                        
                        <div class="price fw-bold text-danger">
                            <%
                                let price_display = (top_sp.gia_khuyen_mai > 0)
                                    ? top_sp.gia_khuyen_mai
                                    : top_sp.gia;
                            %>

                            <%= Number(price_display).toLocaleString('vi-VN') %>đ
                        </div>

                    </a>
                </div>

            <% } %>

        <% } else { %>
            <p class="text-center text-muted">Chưa có đánh giá nào nổi bật.</p>
        <% } %>

    </div>
</div>

<!-- ===== PROMO ===== -->
<div class="promo-banner shadow-sm">
    <img src="../image/bt.jpg" alt="Promotion">
    <div class="promo-content">
        <h2 class="fw-bold">Sản Phẩm Mới</h2>
        <a href="/trangsuc" class="btn btn-light rounded-pill px-4">Xem ngay</a>
    </div>
</div>

<hr class="my-5">

<!-- ===== SLIDER ===== -->
<h2 class="title text-center mt-5 mb-4">Sản phẩm nổi bật</h2>

<div class="product-slider position-relative">

    <button class="slider-btn left btn btn-dark position-absolute top-50 start-0 translate-middle-y z-3"
            onclick="slideLeft()">❮</button>

    <div class="product-container d-flex overflow-hidden" id="productContainer">

        <% if (typeof products !== 'undefined' && products.length > 0) { %>
            <% products.forEach(sp => { %>

                <div class="flex-shrink-0 px-2" style="width: 250px;">

                    <a href="/chitiet/<%= sp._id %>"
                       class="product-card border p-3 d-block text-decoration-none text-dark bg-white h-100">

                        <div class="product-img position-relative text-center">

                            <% if (sp.gia_khuyen_mai && sp.gia > 0) {
                                let giam = 100 - (sp.gia_khuyen_mai / sp.gia * 100);
                            %>
                                <span class="badge bg-danger position-absolute top-0 start-0">
                                    -<%= Math.round(giam) %>%
                                </span>
                            <% } %>

                            <img src="../image/<%= sp.hinh_anh %>"
                                 class="img-fluid"
                                 style="height: 150px; object-fit: contain;">
                        </div>

                        <h6 class="product-name mt-2 text-truncate">
                            <%= sp.ten_sp %>
                        </h6>

                        <div class="price mt-2">
                            <% if (sp.gia_khuyen_mai && sp.gia_khuyen_mai > 0) { %>
                                <span class="text-danger fw-bold">
                                    <%= Number(sp.gia_khuyen_mai).toLocaleString('vi-VN') %>đ
                                </span>
                                <small class="text-decoration-line-through text-muted">
                                    <%= Number(sp.gia).toLocaleString('vi-VN') %>đ
                                </small>
                            <% } else { %>
                                <span class="text-dark fw-bold">
                                    <%= Number(sp.gia).toLocaleString('vi-VN') %>đ
                                </span>
                            <% } %>
                        </div>

                    </a>
                </div>

            <% }) %>
        <% } %>

    </div>

    <button class="slider-btn right btn btn-dark position-absolute top-50 end-0 translate-middle-y z-3"
            onclick="slideRight()">❯</button>

</div>

<!-- ===== BUTTON ===== -->
<div class="text-center mt-5 mb-5">
    <a href="/sanpham"
       class="btn btn-success px-5 py-2 rounded-pill shadow">
        Xem tất cả sản phẩm
    </a>
</div>

</div>

<%- include('footer') %>

<script src="../js/index.js"></script>

</body>
</html>