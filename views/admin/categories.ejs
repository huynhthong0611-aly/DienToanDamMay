<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Danh mục - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="container-fluid">
    <div class="row">

        <%- include('_sidebar', { currentPage: 'categories' }) %>

        <!-- CONTENT -->
        <div class="col-md-9 col-lg-10 content">
            <div class="page-header">
                <h2 class="fw-bold"><i class="fas fa-tags text-success me-2"></i>Quản lý Danh mục</h2>
                <a href="/admin/categories/add" class="btn btn-success">
                    <i class="fas fa-plus me-1"></i> Thêm Danh mục
                </a>
            </div>

            <!-- SUCCESS TOAST -->
            <script>
                const urlParams = new URLSearchParams(window.location.search);
                const s = urlParams.get('success');
                if (s) {
                    const msgs = { add: 'Thêm danh mục thành công!', update: 'Cập nhật thành công!', delete: 'Xóa thành công!' };
                    if (msgs[s]) document.write(`<div class="alert alert-success alert-dismissible fade show"><i class="fas fa-check-circle me-2"></i>${msgs[s]}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`);
                }
            </script>

            <div class="card">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Tên danh mục</th>
                                    <th>Mô tả</th>
                                    <th>Trạng thái</th>
                                    <th class="text-center">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(categories && categories.length > 0) { %>
                                    <% categories.forEach(cat => { %>
                                        <tr>
                                            <td class="ps-4 fw-bold"><%= cat.ten_danh_muc %></td>
                                            <td class="text-muted"><%= cat.mo_ta || '—' %></td>
                                            <td>
                                                <% if(cat.trang_thai === 1) { %>
                                                    <span class="badge bg-success">Hiển thị</span>
                                                <% } else { %>
                                                    <span class="badge bg-secondary">Ẩn</span>
                                                <% } %>
                                            </td>
                                            <td class="text-center">
                                                <a href="/admin/categories/edit/<%= cat._id %>"
                                                   class="btn btn-sm btn-outline-primary" title="Sửa">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a href="/admin/categories/delete/<%= cat._id %>"
                                                   class="btn btn-sm btn-outline-danger"
                                                   title="Xóa"
                                                   onclick="return confirm('Xóa danh mục này?')">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="4" class="text-center py-4 text-muted">Chưa có danh mục nào</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>