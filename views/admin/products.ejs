<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Sản phẩm - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="container-fluid">
    <div class="row">

        <%- include('_sidebar', { currentPage: 'products' }) %>

        <!-- CONTENT -->
        <div class="col-md-9 col-lg-10 content">
            <div class="page-header">
                <h2 class="fw-bold"><i class="fas fa-box-open text-warning me-2"></i>Quản lý Sản phẩm</h2>
                <a href="/admin/products/add" class="btn btn-warning">
                    <i class="fas fa-plus me-1"></i> Thêm Sản phẩm
                </a>
            </div>

            <% if(typeof success !== 'undefined' && success == 1) { %>
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="fas fa-check-circle me-2"></i>Thao tác thành công!
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <!-- SEARCH & FILTER -->
            <div class="card mb-3">
                <div class="card-body py-3">
                    <form method="GET" action="/admin/products" class="d-flex flex-wrap gap-2">
                        <!-- Search input -->
                        <input type="text" name="search" class="form-control" style="max-width:200px;"
                               placeholder="Tìm tên hoặc mã sản phẩm"
                               value="<%= typeof search !== 'undefined' ? search : '' %>">

                        <!-- Category filter -->
                        <select name="danh_muc_id" class="form-select" style="max-width:180px;">
                            <option value="all">Tất cả danh mục</option>
                            <% if(typeof categories !== 'undefined' && categories.length > 0) { %>
                                <% categories.forEach(cat => { %>
                                    <option value="<%= cat._id %>" 
                                        <%= (typeof danh_muc_id !== 'undefined' && danh_muc_id == cat._id) ? 'selected' : '' %>>
                                        <%= cat.ten_danh_muc %>
                                    </option>
                                <% }) %>
                            <% } %>
                        </select>

                        <!-- Status filter -->
                        <select name="trang_thai" class="form-select" style="max-width:150px;">
                            <option value="all">Tất cả trạng thái</option>
                            <option value="1" <%= (typeof trang_thai !== 'undefined' && trang_thai == 1) ? 'selected' : '' %>>Đang bán</option>
                            <option value="0" <%= (typeof trang_thai !== 'undefined' && trang_thai == 0) ? 'selected' : '' %>>Tạm ẩn</option>
                        </select>

                        <!-- Search button -->
                        <button type="submit" class="btn btn-outline-secondary">
                            <i class="fas fa-search"></i> Lọc
                        </button>

                        <!-- Reset button -->
                        <a href="/admin/products" class="btn btn-outline-danger">
                            <i class="fas fa-redo"></i> Đặt lại
                        </a>
                    </form>
                </div>
            </div>

            <div class="card">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Hình ảnh</th>
                                    <th>Thông tin sản phẩm</th>
                                    <th>Giá bán</th>
                                    <th>Trạng thái</th>
                                    <th class="text-center">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(products && products.length > 0) { %>
                                    <% products.forEach(p => { %>
                                        <tr>
                                            <td class="ps-4">
                                                <img src="/image/<%= p.hinh_anh %>" class="rounded shadow-sm"
                                                     width="55" height="55" style="object-fit:cover;"
                                                     onerror="this.src='/image/default.jpg'">
                                            </td>
                                            <td>
                                                <div class="fw-bold"><%= p.ten_sp %></div>
                                                <small class="text-muted">Mã: <%= p.ma_sp %></small>
                                            </td>
                                            <td class="fw-bold text-danger">
                                                <%= p.gia.toLocaleString('vi-VN') %>đ
                                            </td>
                                            <td>
                                                <% if(p.trang_thai === 1) { %>
                                                    <span class="badge bg-success">Đang bán</span>
                                                <% } else { %>
                                                    <span class="badge bg-secondary">Tạm ẩn</span>
                                                <% } %>
                                            </td>
                                            <td class="text-center">
                                                <a href="/admin/products/edit/<%= p._id %>" class="btn btn-sm btn-outline-primary" title="Sửa">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a href="/admin/products/delete/<%= p._id %>"
                                                   class="btn btn-sm btn-outline-danger"
                                                   title="Xóa"
                                                   onclick="return confirm('Xóa sản phẩm này?')">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có sản phẩm nào</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
