<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Trang Sức</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="container-fluid">
    <div class="row">

        <%- include('_sidebar', { currentPage: 'dashboard' }) %>

        <!-- CONTENT -->
        <div class="col-md-9 col-lg-10 content">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-dark"><i class="fas fa-chart-line text-warning"></i> Tổng quan</h2>
                <span class="text-muted">Ngày: <%= new Date().toLocaleDateString('vi-VN') %></span>
            </div>

            <!-- Stats Row -->
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="stat-box">
                        <i class="fas fa-box text-warning"></i>
                        <h3><%= totalProducts %></h3>
                        <p class="text-muted mb-0">Sản phẩm</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-box">
                        <i class="fas fa-shopping-bag text-primary"></i>
                        <h3><%= totalOrders %></h3>
                        <p class="text-muted mb-0">Đơn hàng</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-box">
                        <i class="fas fa-users text-info"></i>
                        <h3><%= totalUsers %></h3>
                        <p class="text-muted mb-0">Khách hàng</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-box">
                        <i class="fas fa-wallet text-success"></i>
                        <h3><%= (totalRevenue / 1000000).toFixed(1) %>M</h3>
                        <p class="text-muted mb-0">Doanh thu (VNĐ)</p>
                    </div>
                </div>
            </div>

            <!-- Recent Orders -->
            <div class="card">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-history text-warning me-2"></i> Đơn hàng gần đây</h5>
                    <a href="/admin/orders" class="btn btn-sm btn-outline-warning">Xem tất cả</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Mã ĐH</th>
                                    <th>Khách hàng</th>
                                    <th>Ngày đặt</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(recentOrders && recentOrders.length > 0) { %>
                                    <% recentOrders.forEach(order => { %>
                                        <tr>
                                            <td class="ps-4 fw-bold text-primary">#<%= order.IdHoaDon %></td>
                                            <td>
                                                <div class="fw-bold"><%= order.HoTenKhachHang %></div>
                                                <small class="text-muted"><%= order.SoDienThoai %></small>
                                            </td>
                                            <td><%= new Date(order.NgayLap).toLocaleDateString('vi-VN') %></td>
                                            <td class="fw-bold text-danger"><%= order.TongTien.toLocaleString('vi-VN') %>đ</td>
                                            <td>
                                                <% if(order.TrangThai === 'Đã giao') { %>
                                                    <span class="badge bg-success rounded-pill px-3"><i class="fas fa-check me-1"></i>Đã giao</span>
                                                <% } else if(order.TrangThai === 'Đang giao') { %>
                                                    <span class="badge bg-primary rounded-pill px-3"><i class="fas fa-truck me-1"></i>Đang giao</span>
                                                <% } else if(order.TrangThai === 'Đã hủy') { %>
                                                    <span class="badge bg-danger rounded-pill px-3"><i class="fas fa-times me-1"></i>Đã hủy</span>
                                                <% } else { %>
                                                    <span class="badge bg-warning text-dark rounded-pill px-3"><i class="fas fa-clock me-1"></i>Chờ xử lý</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có đơn hàng nào</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
