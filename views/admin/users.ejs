<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Users - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="container-fluid">
    <div class="row">

        <%- include('_sidebar', { currentPage: 'users' }) %>

        <!-- CONTENT -->
        <div class="col-md-9 col-lg-10 content">
            <div class="page-header">
                <h2 class="fw-bold"><i class="fas fa-users text-primary me-2"></i>Quản lý Người dùng</h2>
                <a href="/admin/users/add" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i> Thêm User
                </a>
            </div>

            <% if(typeof success !== 'undefined' && success == 1) { %>
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="fas fa-check-circle me-2"></i>Thao tác thành công!
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <div class="card">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Avatar</th>
                                    <th>Thông tin</th>
                                    <th>Số điện thoại</th>
                                    <th>Vai trò</th>
                                    <th class="text-center">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(users && users.length > 0) { %>
                                    <% users.forEach(u => { %>
                                        <tr>
                                            <td class="ps-4">
                                                <img src="/image/<%= u.anh_dai_dien || 'default.jpg' %>"
                                                     class="rounded-circle shadow-sm" width="42" height="42"
                                                     style="object-fit:cover;">
                                            </td>
                                            <td>
                                                <div class="fw-bold"><%= u.HoTen %></div>
                                                <small class="text-muted"><%= u.Email %></small>
                                            </td>
                                            <td><%= u.SoDienThoai || '—' %></td>
                                            <td>
                                                <% if(u.VaiTro === 'Admin') { %>
                                                    <span class="badge bg-danger"><i class="fas fa-user-shield me-1"></i>Admin</span>
                                                <% } else { %>
                                                    <span class="badge bg-secondary"><i class="fas fa-user me-1"></i>Khách hàng</span>
                                                <% } %>
                                            </td>
                                            <td class="text-center">
                                                <a href="/admin/users/edit/<%= u._id %>" class="btn btn-sm btn-outline-primary" title="Sửa">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <% if(u.VaiTro !== 'Admin') { %>
                                                    <a href="/admin/users/delete/<%= u._id %>"
                                                       class="btn btn-sm btn-outline-danger"
                                                       title="Xóa"
                                                       onclick="return confirm('Xóa user này?')">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có user nào</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
