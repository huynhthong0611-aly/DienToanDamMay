<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sửa Danh mục - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="container-fluid">
    <div class="row">

        <%- include('_sidebar', { currentPage: 'categories' }) %>

        <div class="col-md-9 col-lg-10 content">
            <div class="page-header">
                <h2 class="fw-bold"><i class="fas fa-edit text-info me-2"></i>Sửa Danh mục</h2>
                <a href="/admin/categories" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại
                </a>
            </div>

            <div class="card shadow-sm" style="max-width:600px;">
                <div class="card-body p-4">
                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-circle me-2"></i><%= error %>
                        </div>
                    <% } %>

                    <form method="POST" action="/admin/categories/edit/<%= category._id %>">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tên danh mục <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="ten_danh_muc"
                                   value="<%= category.ten_danh_muc %>" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Mô tả</label>
                            <textarea class="form-control" name="mo_ta" rows="3"><%= category.mo_ta || '' %></textarea>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Trạng thái</label>
                            <select class="form-select" name="trang_thai">
                                <option value="1" <%= category.trang_thai === 1 ? 'selected' : '' %>>Hiển thị</option>
                                <option value="0" <%= category.trang_thai === 0 ? 'selected' : '' %>>Ẩn</option>
                            </select>
                        </div>
                        <div class="d-flex gap-2 justify-content-end">
                            <a href="/admin/categories" class="btn btn-secondary">
                                <i class="fas fa-times me-1"></i>Hủy
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i>Cập nhật
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>