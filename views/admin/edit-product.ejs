<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sửa Sản phẩm - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="container-fluid">
    <div class="row">

        <%- include('_sidebar', { currentPage: 'products' }) %>

        <!-- CONTENT -->
        <div class="col-md-9 col-lg-10 content">
            <div class="page-header">
                <h2 class="fw-bold"><i class="fas fa-edit text-info me-2"></i>Sửa Sản phẩm</h2>
                <a href="/admin/products" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại
                </a>
            </div>

            <div class="card">
                <div class="card-body p-4">
                    <form method="POST" action="/admin/products/edit/<%= product._id %>">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Mã SP <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="ma_sp"
                                       value="<%= product.ma_sp %>" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Tên sản phẩm <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="ten_sp"
                                       value="<%= product.ten_sp %>" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Giá bán <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" name="gia"
                                       value="<%= product.gia %>" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Giá khuyến mãi</label>
                                <input type="number" class="form-control" name="gia_khuyen_mai"
                                       value="<%= product.gia_khuyen_mai || 0 %>">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Danh mục ID <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" name="danh_muc_id"
                                       value="<%= product.danh_muc_id %>" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Thương hiệu ID</label>
                                <input type="number" class="form-control" name="thuong_hieu_id"
                                       value="<%= product.thuong_hieu_id || '' %>">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Chất liệu</label>
                                <input type="text" class="form-control" name="chat_lieu"
                                       value="<%= product.chat_lieu || '' %>">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Đá chính</label>
                                <input type="text" class="form-control" name="da_chinh"
                                       value="<%= product.da_chinh || '' %>">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Trạng thái</label>
                                <select class="form-select" name="trang_thai">
                                    <option value="1" <%= product.trang_thai === 1 ? 'selected' : '' %>>Đang bán</option>
                                    <option value="0" <%= product.trang_thai === 0 ? 'selected' : '' %>>Tạm ẩn</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Trọng lượng (gram)</label>
                                <input type="number" step="0.1" class="form-control" name="trong_luong"
                                       value="<%= product.trong_luong || '' %>">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Mô tả</label>
                                <textarea class="form-control" name="mo_ta" rows="4"><%= product.mo_ta || '' %></textarea>
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-end mt-4">
                            <a href="/admin/products" class="btn btn-secondary">
                                <i class="fas fa-times me-1"></i>Hủy
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i>Cập nhật
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
